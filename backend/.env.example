# Copy this file to backend/.env and fill in the key(s) you need.
# Loaded at startup via python-dotenv; read by backend/llm_client.py.
# backend/.env is gitignored — never commit real keys.

# Gemini is the default model — required.
GEMINI_API_KEY=

# Only needed if you select DeepSeek / GPT in the task pane's model dropdown.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Optional overrides. Defaults live in MODEL_REGISTRY in backend/llm_client.py;
# the audit trail records the resolved model id either way.
# GEMINI_MODEL=
# DEEPSEEK_MODEL=
# DEEPSEEK_BASE_URL=
# OPENAI_MODEL=
# OPENAI_BASE_URL=
